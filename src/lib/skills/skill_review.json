# Review Skill
# Produces a complete audit report on the current chapter or project
#
# Follows the architecture described in BMAD:
# bmad/references/project/5-ai-architecture-mcp-skills.md

id: skill_review
description: Produces a comprehensive audit report analyzing narrative quality, consistency, and style. Used for read-only review mode.
task_type: review
trigger:
  - review_mode
  - explicit_request

steps:
  # Set up UI state
  - type: command
    command: ui.set_spinner
    params:
      visible: true

  # Load all project context
  - type: tool
    tool: read_bible
    description: Load the complete bible.yaml

  - type: tool
    tool: read_timeline
    description: Load timeline.yaml

  - type: tool
    tool: read_structure
    description: Load structure.yaml

  - type: tool
    tool: read_themes
    description: Load themes.yaml

  - type: tool
    tool: read_narrator
    description: Load narrator.yaml

  - type: tool
    tool: read_chapter
    params:
      id: "{{scope}}"
    description: Load the chapter to review

  # Generate comprehensive audit report
  - type: prompt
    prompt: |
      You are a professional literary editor. Perform a comprehensive audit of the provided narrative text and project context.
      
      Produce a structured JSON report with the following sections:
      
      {
        "inconsistencies": [
          {
            "entity": "Character/object/location name",
            "issue": "Description of inconsistency",
            "severity": "Low" | "Medium" | "High"
          }
        ],
        "pov_compliance": {
          "issues": [],
          "summary": "Overall POV compliance assessment"
        },
        "narrative_threads": {
          "unresolved": [],
          "resolved": [],
          "summary": "Thread completion assessment"
        },
        "tension_analysis": {
          "current_level": 1-10,
          "target_level": 1-10,
          "consistency": "Consistent" | "Too High" | "Too Low" | "Variable",
          "suggestions": []
        },
        "theme_analysis": {
          "present_themes": [],
          "missing_themes": [],
          "suggestions": []
        },
        "character_voices": {
          "consistent": [],
          "inconsistent": [],
          "suggestions": []
        },
        "language_analysis": {
          "tics": [],
          "repetitions": [],
          "suggestions": []
        },
        "narrative_density": {
          "current": "High" | "Medium" | "Low",
          "suggested": "High" | "Medium" | "Low",
          "notes": ""
        },
        "overall_assessment": "2-3 sentence summary of the text's quality",
        "priority_issues": ["List of 1-3 most critical issues to address"]
      }
      
      Be thorough and specific. Reference the provided context files in your analysis.
      Only return the JSON object, no other text.
    response_format: json
    temperature: 0.3
    max_tokens: 4096

  # Navigate to review screen and display report
  - type: command
    command: app.navigate_to
    params:
      screen: "review"

  - type: command
    command: review.push_report
    params:
      report: "{{prompt_result}}"
    on_error: ignore

  # Clean up UI state
  - type: command
    command: ui.set_spinner
    params:
      visible: false

metadata:
  version: "1.0"
  author: "Sive Team"
  created_at: "2024-01-01"
  updated_at: "2024-01-01"
